# =============================================================================
# HP ALM MCP Server — environment configuration
# =============================================================================
# Copy this file to .env, fill in your values, and NEVER commit .env to Git.
# All variables are prefixed ALM_ (handled automatically by pydantic-settings).

# -- Required -----------------------------------------------------------------

# Base URL of your HP ALM / Quality Center server (no trailing slash)
ALM_BASE_URL=https://your-alm-server.example.com/qcbin

# ALM credentials
ALM_USERNAME=your_username
ALM_PASSWORD=your_password

# ALM domain and project to operate on
ALM_DOMAIN=YOUR_DOMAIN
ALM_PROJECT=YOUR_PROJECT

# -- Optional -----------------------------------------------------------------

# Seconds to sleep between consecutive API calls (default: 2.0).
# Increase this if your ALM server throttles rapid requests.
# ALM_REQUEST_DELAY=2.0
